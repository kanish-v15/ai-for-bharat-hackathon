# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET=swasthyamitra-uploads

# DynamoDB Tables
DYNAMODB_USERS_TABLE=swasthyamitra-users
DYNAMODB_INTERACTIONS_TABLE=swasthyamitra-interactions
DYNAMODB_ENTITIES_TABLE=swasthyamitra-medical-entities

# Amazon Bedrock
BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0
BEDROCK_LITE_MODEL_ID=us.amazon.nova-2-lite-v1:0

# Amazon Cognito
COGNITO_USER_POOL_ID=your_user_pool_id
COGNITO_APP_CLIENT_ID=your_app_client_id

# Sarvam AI (fallback TTS for regional languages)
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_API_BASE=https://api.sarvam.ai

# App
ENVIRONMENT=development
MAX_FILE_SIZE_MB=10
