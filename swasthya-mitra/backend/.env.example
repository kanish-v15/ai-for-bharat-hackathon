# AWS Configuration
AWS_REGION=ap-south-1
S3_BUCKET=swasthyamitra-uploads

# DynamoDB
DYNAMODB_TABLE=swasthyamitra-interactions

# Bedrock Models
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20250514-v1:0
BEDROCK_LITE_MODEL_ID=amazon.nova-lite-v1:0

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_API_BASE=https://api.sarvam.ai

# App
ENVIRONMENT=development
MAX_FILE_SIZE_MB=10
